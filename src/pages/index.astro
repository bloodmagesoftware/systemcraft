---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import heroImage from "../assets/hero.webp";
import HammerIcon from "../components/Hammer.astro";
import LightIcon from "../components/Light.astro";
import WrenchIcon from "../components/Wrench.astro";
import BookmarkIcon from "../components/Bookmark.astro";
---

<Layout>
	<section
		class="hero relative h-lvh w-full bg-cover bg-center bg-no-repeat"
		style={`background-image: url("${heroImage.src}")`}
	>
		<div class="absolute top-1/6 block h-fit w-full">
			<div
				class="mx-auto block w-fit"
				style={{
					filter:
						"drop-shadow(0 0 1rem black) drop-shadow(0 0 2rem black) drop-shadow(0 0 5rem black) drop-shadow(0 0 10rem black)",
				}}
			>
				<h1 class="mb-8 w-full text-center font-serif text-5xl">SystemCraft</h1>
				<p class="w-full text-center text-xl text-balance text-gray-400">
					Get the best resources that will actually help you become a good
					software engineer.
					<br />
					Take a look at our courses, they are all free.
				</p>
			</div>
			<a
				class="cta mx-auto mt-16 block w-fit rounded border-3 border-solid border-cyan-700 bg-blue-950 px-8 py-2 font-serif text-2xl shadow-2xl shadow-blue-700/40"
				href="/courses">Get started</a
			>
		</div>
		<div class="absolute right-0 bottom-0 left-0 block h-3 bg-slate-700">
			<div
				class="mx-auto block h-3 w-3 scale-[3] rotate-45 border-3 border-solid border-cyan-600 bg-cyan-500"
			>
			</div>
		</div>
	</section>

	<section class="py-24">
		<h2 class="mb-24 text-center font-serif text-2xl">Our approach</h2>
		<ul
			class="mx-auto grid w-full max-w-5xl grid-cols-1 gap-x-8 gap-y-16 px-2 md:grid-cols-2"
		>
			{
				[
					{
						icon: HammerIcon,
						title: "Hands-on approach",
						text: "We provide a hands-on approach to learning with interactive examples whenever possible.",
					},
					{
						icon: LightIcon,
						title: "Example solutions",
						text: "There are a lot of example projects for you to put into practice what you've learned. We provide example solutions for each exercise you can look at and compare it with your solution.",
					},
					{
						icon: WrenchIcon,
						title: "Setup guides",
						text: "We provide setup guides for all required software to get up and running as fast as possible.",
					},
					{
						icon: BookmarkIcon,
						title: "Account",
						text: "Login using GitHub or Google to save your progress and settings.",
					},
				].map((item) => (
					<li class="grid grid-cols-[auto_1fr] grid-rows-[auto_1fr] gap-x-4 gap-y-2">
						<item.icon class="mb-2 block h-6 w-6 fill-cyan-500" />
						<span class="text-xl">{item.title}</span>
						<span class="col-span-2 block text-balance text-gray-400">
							{item.text}
						</span>
					</li>
				))
			}
		</ul>
	</section>

	<Footer />
</Layout>

<style>
	.cta {
		position: relative;
		overflow: clip;
	}
	.cta:not(:hover)::before {
		translate: -1rem 0;
	}
	.cta:not(:hover)::after {
		translate: 1rem 0;
	}
	.cta::before,
	.cta::after {
		transition: translate 100ms ease-out;
		width: 0px;
		height: 0px;
		border-style: solid;
		position: absolute;
		display: block;
		content: "";
		top: 1rem;
		z-index: 1;
	}
	.cta::before {
		border-color: transparent transparent transparent var(--color-cyan-700);
		border-width: 0.5rem 0 0.5rem 0.4rem;
		left: 0;
	}
	.cta::after {
		border-color: transparent var(--color-cyan-700) transparent transparent;
		border-width: 0.5rem 0.4rem 0.5rem 0;
		right: 0;
	}
</style>
